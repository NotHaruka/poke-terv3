{
  "name": "poke-ter",
  "version": "1.0.0",
  "description": "Multiplayer Poke-ter game with client, server, and shared library.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/src/index.ts",
    "build": "vite build client --emptyOutDir --outDir ../dist/client && esbuild server/src/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "echo 'No linting'"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
