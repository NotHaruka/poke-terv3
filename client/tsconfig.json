{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
  "types": [
    "vite/client",
    "node"
  ],
    "skipLibCheck": true,
    "paths": {
      "poke-ter-shared": ["../shared/src/index.ts"],
      "*": ["./*"]
    }
  },
  "include": [
    "src",
    "../shared/src"
  ]
}